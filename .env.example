# Database
DB_URL=jdbc:postgresql://localhost:5432/tabriko
DB_USERNAME=tabriko
DB_PASSWORD=tabriko

# JWT — change these in production! Must be at least 32 characters.
JWT_ACCESS_SECRET=tabriko-access-secret-key-must-be-at-least-32-chars-long!!
JWT_REFRESH_SECRET=tabriko-refresh-secret-key-must-be-at-least-32-chars-long!

# Token expiry (milliseconds)
JWT_ACCESS_EXPIRY_MS=3600000       # 1 hour
JWT_REFRESH_EXPIRY_MS=2592000000   # 30 days

# Business config
COMMISSION_PERCENT=15              # Platform commission %

# Media storage
STORAGE_PROVIDER=local             # local | s3
MEDIA_UPLOAD_DIR=./uploads
MEDIA_BASE_URL=http://localhost:8080/files
MEDIA_MAX_SIZE_MB=100
BASE_URL=http://localhost:8080

# S3 / S3-compatible storage (required when STORAGE_PROVIDER=s3)
S3_ENDPOINT=                       # Leave empty for AWS; set for MinIO/Localstack
S3_BUCKET=tabriko-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Payment providers (STUB — replace with real keys in production)
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Firebase (leave empty to use mock OTP/push in dev)
FIREBASE_CREDENTIALS_PATH=

# Server port
PORT=8080
